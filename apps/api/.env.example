# Live-feed credentials for the Orbital Ops API. Copy to .env (or export in your
# shell) — all three are optional, but the feeds degrade without them.

# aisstream.io API key for the live ship (AIS) feed. Register for a free key at
# https://aisstream.io — without it the AIS feed stays off and /api/ships returns 503.
AISSTREAM_API_KEY=

# OpenSky Network OAuth2 client credentials for the aircraft (ADS-B) feed.
# Create an account and an API client at https://opensky-network.org — with
# credentials the API polls /states/all every 60 s; without them it falls back
# to heavily rate-limited anonymous polling every 600 s.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
